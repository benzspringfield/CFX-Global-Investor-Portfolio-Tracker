# ===== ตัวอย่าง secrets — คัดลอกเนื้อหานี้ไปวางในหน้า Settings > Secrets ของ Streamlit Cloud =====
# (อย่า commit ไฟล์ secrets.toml จริง — มันอยู่ใน .gitignore แล้ว)

# รหัสผ่านเข้าแอป (ตั้งเป็นอะไรก็ได้ที่เดายาก)
APP_PASSWORD = "เปลี่ยนเป็นรหัสผ่านของคุณ"

# อีเมลสำหรับ SEC (ใส่อีเมลจริงของคุณ — SEC บังคับ)
SEC_USER_AGENT = "Portfolios-Tracker your-email@example.com"

# OpenFIGI API key (ไม่จำเป็น เว้นว่างได้ — ใช้แปลง CUSIP->ticker)
OPENFIGI_API_KEY = ""
